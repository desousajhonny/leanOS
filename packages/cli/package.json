{
  "name": "lean-os",
  "version": "0.1.5",
  "description": "LeanOS agent-native startup operating system CLI.",
  "type": "module",
  "bin": {
    "lean-os": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "generate:client-workspace": "npm run build && node scripts/generate-client-workspace.mjs",
    "start": "node dist/index.js",
    "test:generator": "npm run build && node scripts/validate-generator.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "figlet": "^1.8.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.18"
  }
}
